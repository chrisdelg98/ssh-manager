# =====================================================================
# SSH Manager — environment configuration template
# =====================================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#   chmod 600 .env
# NEVER commit your real .env to version control.
# =====================================================================

# ── Database (MySQL / MariaDB) ───────────────────────────────────────
DB_HOST=localhost
DB_NAME=sshmanager
DB_USER=sshmanager
DB_PASS=change-me-please
DB_CHARSET=utf8mb4

# ── App ──────────────────────────────────────────────────────────────
APP_NAME="SSH Manager"
APP_ENV=production
APP_DEBUG=false

# ── Sessions ─────────────────────────────────────────────────────────
# Inactivity timeout in seconds (1800 = 30 min).
SESSION_TIMEOUT=1800

# ── Login security ───────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── Audit logs ───────────────────────────────────────────────────────
LOG_RETENTION_DAYS=90

# ── SSH ──────────────────────────────────────────────────────────────
SSH_TIMEOUT=15
SSH_OUTPUT_LIMIT=51200

# ── IP allowlist (optional) ──────────────────────────────────────────
# Comma-separated list of IPs allowed to access the app.
# Empty = allow all. Example: 203.0.113.5,198.51.100.10
IP_ALLOWLIST=
